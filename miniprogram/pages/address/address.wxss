.page-hero,
.card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 42rpx rgba(66, 38, 28, 0.07);
}

.page-hero {
  background: linear-gradient(145deg, #ffe5de 0%, #fff8f1 100%);
}

.page-title,
.page-desc,
.section-title,
.field-label,
.address-text,
.empty {
  display: block;
}

.page-title {
  color: #2f1f1c;
  font-size: 44rpx;
  font-weight: 900;
}

.page-desc,
.empty {
  margin-top: 12rpx;
  color: #8a6d64;
  font-size: 25rpx;
  line-height: 1.55;
}

.section-title {
  margin-bottom: 20rpx;
  color: #2f1f1c;
  font-size: 32rpx;
  font-weight: 900;
}

.field-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 16rpx;
}

.field-label {
  width: 130rpx;
  color: #7b5b54;
  font-size: 26rpx;
}

.field-input {
  flex: 1;
  height: 74rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  background: #fff8f5;
  font-size: 26rpx;
}

.address-block {
  margin-top: 18rpx;
}

.address-label {
  width: auto;
  margin-bottom: 12rpx;
}

.address-input {
  box-sizing: border-box;
  width: 100%;
  min-height: 150rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #fff8f5;
  font-size: 26rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  color: #6f4b43;
  font-size: 26rpx;
}

.save-btn,
.reset-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  line-height: 1;
  margin-top: 22rpx;
}

.address-item {
  margin-top: 18rpx;
  padding: 22rpx;
  border: 2rpx solid #f2dfd8;
  border-radius: 24rpx;
  background: #fffdfb;
}

.address-top {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.receiver {
  color: #2f1f1c;
  font-size: 30rpx;
  font-weight: 900;
}

.phone {
  color: #8a6d64;
  font-size: 24rpx;
}

.default-badge {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  color: #e54862;
  background: #fff0f2;
  font-size: 20rpx;
  font-weight: 800;
}

.address-text {
  margin-top: 12rpx;
  color: #6f4b43;
  font-size: 25rpx;
  line-height: 1.55;
}

.action-row {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

.action-row button {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  line-height: 1;
}

.danger {
  color: #b42318;
}
