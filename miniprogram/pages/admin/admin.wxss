.admin-hero,
.card {
  margin-bottom: 24rpx;
  padding: 30rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 42rpx rgba(66, 38, 28, 0.07);
}

.admin-hero {
  background: linear-gradient(145deg, #ffe5de 0%, #fff8f1 100%);
}

.admin-eyebrow,
.admin-title,
.admin-desc,
.section-title,
.section-desc,
.mini-title,
.product-name,
.product-meta,
.order-title,
.order-meta,
.empty {
  display: block;
}

.admin-eyebrow {
  margin-bottom: 8rpx;
  color: #e54862;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.admin-title {
  color: #2f1f1c;
  font-size: 42rpx;
  font-weight: 900;
}

.admin-desc,
.section-desc,
.product-meta,
.order-meta,
.empty {
  margin-top: 10rpx;
  color: #8a6d64;
  font-size: 24rpx;
  line-height: 1.55;
}

.section-title {
  color: #2f1f1c;
  font-size: 32rpx;
  font-weight: 900;
}

.product-create-card {
  border: 2rpx solid #ffe0d8;
}

.form-field {
  margin-top: 20rpx;
}

.form-label {
  display: block;
  margin-bottom: 10rpx;
  color: #6f4b43;
  font-size: 24rpx;
  font-weight: 800;
}

.form-grid {
  display: flex;
  gap: 16rpx;
}

.form-grid .form-field {
  flex: 1;
}

.form-input,
.form-textarea {
  box-sizing: border-box;
  width: 100%;
  padding: 0 20rpx;
  border-radius: 20rpx;
  background: #fff8f5;
  color: #2f1f1c;
  font-size: 26rpx;
}

.form-input {
  height: 72rpx;
}

.form-textarea {
  min-height: 130rpx;
  padding-top: 18rpx;
  line-height: 1.5;
}

.cover-uploader,
.cover-preview {
  border-radius: 24rpx;
  background: #fff8f5;
}

.cover-uploader {
  display: flex;
  min-height: 220rpx;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  border: 2rpx dashed #ffd0c6;
  color: #8a6d64;
}

.cover-plus {
  color: #e54862;
  font-size: 54rpx;
  font-weight: 900;
  line-height: 1;
}

.cover-title {
  margin-top: 10rpx;
  color: #6f4b43;
  font-size: 26rpx;
  font-weight: 900;
}

.cover-tip {
  margin-top: 8rpx;
  color: #a98c83;
  font-size: 22rpx;
}

.cover-preview {
  overflow: hidden;
}

.cover-image {
  display: block;
  width: 100%;
  height: 260rpx;
  background: #fff0ec;
}

.cover-actions {
  display: flex;
  gap: 12rpx;
  padding: 16rpx;
}

.cover-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  line-height: 1;
  margin: 0;
}

.mode-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.mode-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  line-height: 1;
  margin: 0;
  color: #8a6d64;
  background: #fff8f5;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.mode-btn.active {
  color: #ffffff;
  background: linear-gradient(135deg, #ff7a90 0%, #ff9f6e 100%);
  font-weight: 800;
}

.import-input {
  box-sizing: border-box;
  width: 100%;
  min-height: 170rpx;
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #fff8f5;
  font-size: 26rpx;
}

.discount-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin: 20rpx 0;
  color: #6f4b43;
  font-size: 26rpx;
}

.discount-input,
.stock-input {
  height: 68rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: #fff8f5;
  font-size: 26rpx;
}

.discount-input {
  width: 120rpx;
  text-align: center;
}

.white-list {
  margin-top: 24rpx;
}

.mini-title {
  margin-bottom: 12rpx;
  color: #6f4b43;
  font-size: 24rpx;
  font-weight: 800;
}

.white-item,
.product-admin,
.order-item {
  padding: 20rpx;
  border-radius: 22rpx;
  background: #fff8f5;
}

.white-item {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
  color: #6f4b43;
  font-size: 24rpx;
}

.product-admin,
.order-item {
  margin-top: 18rpx;
}

.product-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.product-name,
.order-title {
  color: #2f1f1c;
  font-size: 28rpx;
  font-weight: 800;
}

.source-tag,
.info-chip {
  display: inline-block;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.source-tag {
  padding: 4rpx 12rpx;
  color: #e54862;
  background: #ffecef;
  font-weight: 800;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.info-chip {
  padding: 8rpx 12rpx;
  color: #7c5d55;
  background: #ffffff;
}

.action-row,
.stock-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.action-row button {
  flex: 1 0 128rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  line-height: 1;
  padding: 0 8rpx;
  font-size: 22rpx;
}

.danger-btn {
  color: #d93025;
  background: #fff0ee;
  border-radius: 999rpx;
  font-weight: 800;
}

.stock-row {
  align-items: center;
}

.sku-stock-row {
  margin-top: 18rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: #ffffff;
}

.sku-stock-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  color: #6f4b43;
  font-size: 24rpx;
}

.sku-stock-name {
  font-weight: 800;
}

.sku-stock-count {
  color: #e54862;
  font-weight: 800;
}

.stock-input {
  flex: 1 0 180rpx;
}

.stock-btn {
  flex: 1 0 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  line-height: 1;
  padding: 0 8rpx;
  font-size: 22rpx;
}

.setup-action {
  padding: 24rpx;
  text-align: center;
  font-size: 30rpx;
}

.pickup-card {
  border: 2rpx solid #ffe7cd;
}

.editing-tip {
  margin-top: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  color: #b45309;
  background: #fff7ed;
  font-size: 24rpx;
  font-weight: 800;
}

.pickup-action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.pickup-action-row button {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  line-height: 1;
  margin: 0;
}

.pickup-list-admin {
  margin-top: 28rpx;
}

.pickup-admin-item,
.order-admin-item {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #fff8f5;
}

.pickup-admin-item.disabled {
  opacity: 0.68;
}

.pickup-admin-head,
.order-admin-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.pickup-status {
  flex: 0 0 auto;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.pickup-status.on {
  color: #15803d;
  background: #dcfce7;
}

.pickup-status.off {
  color: #8a6d64;
  background: #f1e5df;
}

.order-admin-item {
  background: #fff8f5;
}

.order-id-mini {
  flex: 0 0 auto;
  max-width: 210rpx;
  color: #b8a29b;
  font-size: 20rpx;
  line-height: 1.4;
  text-align: right;
  word-break: break-all;
}

.fulfillment-box {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #ffffff;
}

.fulfillment-box .stock-input {
  min-width: 210rpx;
}

.shipping-rule-card {
  border: 2rpx solid #dbeafe;
}

.filter-block {
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: #fff8f5;
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.filter-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  line-height: 1;
  margin: 0;
  color: #8a6d64;
  background: #ffffff;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.filter-btn.active {
  color: #ffffff;
  background: linear-gradient(135deg, #ff7a90 0%, #ff9f6e 100%);
  font-weight: 800;
}

.aftersale-box {
  border: 2rpx solid #fff0d5;
}
