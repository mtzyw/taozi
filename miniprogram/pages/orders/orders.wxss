.page-hero,
.order-card,
.empty-card {
  margin-bottom: 24rpx;
  padding: 30rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 42rpx rgba(66, 38, 28, 0.07);
}

.page-hero {
  background: linear-gradient(145deg, #ffe5de 0%, #fff8f1 100%);
}

.order-tabs {
  margin: 0 0 22rpx;
  white-space: nowrap;
}

.tab-row {
  display: inline-flex;
  gap: 14rpx;
  padding-bottom: 6rpx;
}

.order-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  color: #7b5b54;
  background: #fff9f5;
  font-size: 24rpx;
  font-weight: 800;
}

.order-tab.active {
  color: #ffffff;
  background: linear-gradient(135deg, #ff7a90 0%, #ff9f6e 100%);
  box-shadow: 0 10rpx 24rpx rgba(229, 72, 98, 0.18);
}

.page-title,
.page-desc,
.order-title,
.order-meta,
.empty-title,
.empty-desc {
  display: block;
}

.page-title {
  color: #2f1f1c;
  font-size: 44rpx;
  font-weight: 900;
}

.page-desc,
.order-meta,
.empty-desc {
  margin-top: 10rpx;
  color: #8a6d64;
  font-size: 25rpx;
  line-height: 1.55;
}

.order-top,
.amount-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.order-status {
  color: #e54862;
  font-size: 25rpx;
  font-weight: 800;
}

.order-id {
  color: #b8a29b;
  font-size: 22rpx;
}

.order-title {
  margin-top: 18rpx;
  color: #2f1f1c;
  font-size: 32rpx;
  font-weight: 900;
}

.amount-row {
  margin-top: 22rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f3e2dc;
  color: #2f1f1c;
  font-size: 30rpx;
  font-weight: 900;
}

.detail-link {
  display: block;
  margin-top: 16rpx;
  color: #e54862;
  font-size: 24rpx;
  font-weight: 800;
  text-align: right;
}

.empty-card {
  text-align: center;
}

.empty-title {
  color: #2f1f1c;
  font-size: 34rpx;
  font-weight: 900;
}

.empty-desc {
  margin-bottom: 28rpx;
}
